<features xmlns="http://karaf.apache.org/xmlns/features/v1.2.0" name="HBaseConnector-features">
  <feature name="hbase-connector" version="3.0.0" description="Water HBase Connector microservice integration">
    <!-- HBase Connector API -->
    <bundle>mvn:it.water.connectors.hbase/HBaseConnector-api/3.0.0</bundle>
    <!-- HBase Connector Model -->
    <bundle>mvn:it.water.connectors.hbase/HBaseConnector-model/3.0.0</bundle>
    <!-- HBase Connector Service (OSGi bundle) -->
    <bundle start-level="85">mvn:it.water.connectors.hbase/HBaseConnector-service/3.0.0</bundle>
    <!-- HBase Client library -->
    <bundle>mvn:org.apache.hbase/hbase-client/2.6.1</bundle>
    <!-- HBase dependencies -->
    <bundle>mvn:org.apache.hadoop/hadoop-common/3.3.6</bundle>
    <bundle>mvn:org.apache.hadoop/hadoop-hdfs/3.3.6</bundle>
    <bundle>mvn:org.apache.zookeeper/zookeeper/3.8.3</bundle>
  </feature>
</features>
